# Normalise line endings to LF in the repository.
# Windows contributors get LF on checkout — no CRLF conversion.
* text=auto eol=lf

# TypeScript / JavaScript source — always text, LF
*.ts   text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.md   text eol=lf

# Binary assets — never diff or normalise
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.otf  binary
*.mp3  binary
*.ogg  binary
*.wav  binary
